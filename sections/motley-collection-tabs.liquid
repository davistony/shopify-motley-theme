{%- assign accent = section.settings.accent_color | default: '#c8102e' -%}
{%- assign ppr = section.settings.products_per_row | default: 4 -%}
{%- assign default_tab = section.settings.default_tab | default: 'tab1' -%}
{%- assign uid = section.id | replace: '.', '-' -%}
{%- assign col1 = section.settings.tab_1_collection -%}
{%- assign col2 = section.settings.tab_2_collection -%}
{%- assign tab1_label = section.settings.tab_1_label | default: 'Street' -%}
{%- assign tab2_label = section.settings.tab_2_label | default: 'Performance' -%}
{%- capture sizes_attr -%}(max-width: 760px) 100vw, calc((100vw - 80px) / {{ ppr }}){%- endcapture -%}

<style>
  #shopify-section-{{ section.id }} .mct { padding: 44px 0; }
  #shopify-section-{{ section.id }} .mct__heading {
    font-family: var(--heading-font-family); font-weight: var(--heading-font-weight, 700);
    text-transform: uppercase; text-align: center; font-size: clamp(26px, 3.5vw, 40px); margin: 0 0 22px;
  }
  #shopify-section-{{ section.id }} .mct__tabs {
    display: flex; max-width: 560px; margin: 0 auto 28px;
    border: 2px solid {{ accent }}; border-radius: 999px; overflow: hidden;
  }
  #shopify-section-{{ section.id }} .mct__tab {
    flex: 1 1 50%; min-height: 48px; padding: 12px 16px; cursor: pointer; background: transparent; border: 0;
    font-family: var(--heading-font-family); text-transform: uppercase; letter-spacing: .06em;
    font-size: 14px; font-weight: 700; color: rgba(20,20,20,.45); transition: background .2s ease, color .2s ease;
  }
  #shopify-section-{{ section.id }} .mct__tab[aria-selected="true"] { background: {{ accent }}; color: #fff; }
  #shopify-section-{{ section.id }} .mct__grid {
    display: grid; grid-template-columns: repeat({{ ppr }}, minmax(0, 1fr)); gap: 24px;
  }
  #shopify-section-{{ section.id }} .mct__grid[hidden] { display: none; }
  #shopify-section-{{ section.id }} .mct__empty { text-align: center; opacity: .6; padding: 24px 0; }
  @media screen and (max-width: 760px) {
    #shopify-section-{{ section.id }} .mct__grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>

<div class="mct container">
  {%- if section.settings.heading != blank -%}
    <h2 class="mct__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="mct__tabs" role="tablist" aria-label="{{ section.settings.heading | default: 'Collections' | escape }}">
    <button type="button" class="mct__tab" id="{{ uid }}-tab1" role="tab" aria-controls="{{ uid }}-panel1" aria-selected="{% if default_tab == 'tab1' %}true{% else %}false{% endif %}" tabindex="{% if default_tab == 'tab1' %}0{% else %}-1{% endif %}" data-mct-tab="1">{{ tab1_label | escape }}</button>
    <button type="button" class="mct__tab" id="{{ uid }}-tab2" role="tab" aria-controls="{{ uid }}-panel2" aria-selected="{% if default_tab == 'tab2' %}true{% else %}false{% endif %}" tabindex="{% if default_tab == 'tab2' %}0{% else %}-1{% endif %}" data-mct-tab="2">{{ tab2_label | escape }}</button>
  </div>

  <div class="mct__grid" id="{{ uid }}-panel1" role="tabpanel" aria-labelledby="{{ uid }}-tab1" data-mct-panel="1"{% if default_tab != 'tab1' %} hidden{% endif %}>
    {%- for product in col1.products limit: section.settings.products_to_show -%}
      {%- render 'product-item', product: product, sizes_attribute: sizes_attr, reveal: false -%}
    {%- else -%}
      <p class="mct__empty">No products in this collection yet.</p>
    {%- endfor -%}
  </div>

  <div class="mct__grid" id="{{ uid }}-panel2" role="tabpanel" aria-labelledby="{{ uid }}-tab2" data-mct-panel="2"{% if default_tab != 'tab2' %} hidden{% endif %}>
    {%- for product in col2.products limit: section.settings.products_to_show -%}
      {%- render 'product-item', product: product, sizes_attribute: sizes_attr, reveal: false -%}
    {%- else -%}
      <p class="mct__empty">No products in this collection yet.</p>
    {%- endfor -%}
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root || root.dataset.mctInit) return;
    root.dataset.mctInit = '1';
    var tabs = Array.prototype.slice.call(root.querySelectorAll('.mct__tab'));
    var panels = Array.prototype.slice.call(root.querySelectorAll('.mct__grid'));
    function activate(n) {
      tabs.forEach(function (t) {
        var on = t.getAttribute('data-mct-tab') === n;
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.setAttribute('tabindex', on ? '0' : '-1');
      });
      panels.forEach(function (p) {
        if (p.getAttribute('data-mct-panel') === n) { p.removeAttribute('hidden'); }
        else { p.setAttribute('hidden', ''); }
      });
    }
    tabs.forEach(function (t) {
      t.addEventListener('click', function () { activate(t.getAttribute('data-mct-tab')); });
      t.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
          e.preventDefault();
          var other = t.getAttribute('data-mct-tab') === '1' ? '2' : '1';
          activate(other);
          var btn = root.querySelector('.mct__tab[data-mct-tab="' + other + '"]');
          if (btn) btn.focus();
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Motley Collection Tabs",
  "tag": "section",
  "class": "shopify-section--motley-collection-tabs",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "info": "Optional" },
    { "type": "header", "content": "Tab 1" },
    { "type": "text", "id": "tab_1_label", "label": "Tab 1 label", "default": "Street" },
    { "type": "collection", "id": "tab_1_collection", "label": "Tab 1 collection" },
    { "type": "header", "content": "Tab 2" },
    { "type": "text", "id": "tab_2_label", "label": "Tab 2 label", "default": "Performance" },
    { "type": "collection", "id": "tab_2_collection", "label": "Tab 2 collection" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "label": "Products to show", "default": 8 },
    { "type": "range", "id": "products_per_row", "min": 2, "max": 5, "step": 1, "label": "Products per row (desktop)", "default": 4 },
    {
      "type": "select",
      "id": "default_tab",
      "label": "Default tab",
      "options": [
        { "value": "tab1", "label": "Tab 1" },
        { "value": "tab2", "label": "Tab 2" }
      ],
      "default": "tab1"
    },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#c8102e" }
  ],
  "presets": [
    {
      "name": "Motley Collection Tabs",
      "settings": {
        "heading": "Pick Your Lane",
        "tab_1_label": "Street",
        "tab_2_label": "Performance",
        "products_to_show": 8,
        "products_per_row": 4,
        "default_tab": "tab1"
      }
    }
  ]
}
{% endschema %}

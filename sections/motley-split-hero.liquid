{%- assign panel_count = section.blocks.size | default: 2 -%}
{%- case section.settings.height -%}
  {%- when '60vh' -%}{%- assign panel_height = '60vh' -%}
  {%- when '100vh' -%}{%- assign panel_height = '100vh' -%}
  {%- else -%}{%- assign panel_height = '78vh' -%}
{%- endcase -%}

<style>
  #shopify-section-{{ section.id }} .msh {
    display: grid;
    grid-template-columns: repeat({{ panel_count | at_least: 1 }}, 1fr);
    position: relative;
  }
  #shopify-section-{{ section.id }} .msh__panel {
    position: relative;
    min-height: {{ panel_height }};
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    isolation: isolate;
  }
  #shopify-section-{{ section.id }} .msh__media { position: absolute; inset: 0; z-index: -2; }
  #shopify-section-{{ section.id }} .msh__media img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform .6s ease;
  }
  #shopify-section-{{ section.id }} .msh__panel:hover .msh__media img { transform: scale(1.05); }
  #shopify-section-{{ section.id }} .msh__overlay {
    position: absolute; inset: 0; z-index: -1;
    background: linear-gradient(180deg, rgba(0,0,0,.12) 0%, rgba(0,0,0,.45) 55%, rgba(0,0,0,.78) 100%);
  }
  #shopify-section-{{ section.id }} .msh__content { padding: 9% 7%; color: #fff; max-width: 560px; position: relative; }
  #shopify-section-{{ section.id }} .msh__kicker {
    text-transform: uppercase; letter-spacing: .14em; font-size: 12px; font-weight: 700; margin: 0 0 10px;
  }
  #shopify-section-{{ section.id }} .msh__heading {
    font-family: var(--heading-font-family); font-weight: var(--heading-font-weight, 700);
    text-transform: uppercase; line-height: .95; margin: 0 0 14px;
    font-size: clamp(40px, 6vw, 88px);
  }
  #shopify-section-{{ section.id }} .msh__text { margin: 0 0 22px; font-size: 16px; line-height: 1.45; opacity: .92; }
  #shopify-section-{{ section.id }} .msh__btn {
    display: inline-block; padding: 14px 28px; background: #fff; color: #111;
    text-transform: uppercase; letter-spacing: .08em; font-weight: 700; font-size: 13px;
    border: 2px solid #fff; transition: background .25s ease, color .25s ease;
  }
  #shopify-section-{{ section.id }} .msh__panel:hover .msh__btn { background: transparent; color: #fff; }
  #shopify-section-{{ section.id }} .msh__link { position: absolute; inset: 0; z-index: 1; }
  {%- if section.settings.show_divider and panel_count == 2 -%}
  #shopify-section-{{ section.id }} .msh__divider {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 2;
    width: 54px; height: 54px; border-radius: 50%; background: #111; color: #fff;
    display: flex; align-items: center; justify-content: center; border: 2px solid #fff;
    font-family: var(--heading-font-family); font-weight: 700; font-size: 20px;
  }
  {%- endif -%}
  @media screen and (max-width: 760px) {
    #shopify-section-{{ section.id }} .msh { grid-template-columns: 1fr; }
    #shopify-section-{{ section.id }} .msh__panel { min-height: 62vh; }
    #shopify-section-{{ section.id }} .msh__heading { font-size: clamp(38px, 13vw, 64px); }
    #shopify-section-{{ section.id }} .msh__divider { display: none; }
  }
</style>

<div class="msh">
  {%- for block in section.blocks -%}
    {%- assign accent = block.settings.accent_color | default: '#c8102e' -%}
    <div class="msh__panel" {{ block.shopify_attributes }}>
      <div class="msh__media">
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '600,800,1000,1200,1600,2000', sizes: '(max-width: 760px) 100vw, 50vw', alt: block.settings.heading | escape }}
        {%- else -%}
          <div style="position:absolute;inset:0;background:linear-gradient(135deg, {{ accent }} 0%, #111 100%);"></div>
        {%- endif -%}
      </div>
      <div class="msh__overlay"></div>
      <div class="msh__content">
        {%- if block.settings.kicker != blank -%}
          <p class="msh__kicker" style="color: {{ accent }};">{{ block.settings.kicker | escape }}</p>
        {%- endif -%}
        {%- if block.settings.heading != blank -%}
          <h2 class="msh__heading">{{ block.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if block.settings.text != blank -%}
          <p class="msh__text">{{ block.settings.text | escape }}</p>
        {%- endif -%}
        {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
          <span class="msh__btn">{{ block.settings.button_label | escape }}</span>
        {%- endif -%}
      </div>
      {%- if block.settings.button_link != blank -%}
        <a class="msh__link" href="{{ block.settings.button_link }}" aria-label="{{ block.settings.heading | default: block.settings.button_label | escape }}"></a>
      {%- endif -%}
    </div>
  {%- endfor -%}

  {%- if section.settings.show_divider and section.blocks.size == 2 -%}
    <div class="msh__divider" aria-hidden="true">{{ section.settings.divider_text | default: '/' }}</div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Motley Split Hero",
  "tag": "section",
  "class": "shopify-section--motley-split-hero",
  "max_blocks": 3,
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "select",
      "id": "height",
      "label": "Panel height",
      "options": [
        { "value": "60vh", "label": "Short (60vh)" },
        { "value": "78vh", "label": "Medium (78vh)" },
        { "value": "100vh", "label": "Full screen (100vh)" }
      ],
      "default": "78vh"
    },
    { "type": "checkbox", "id": "show_divider", "label": "Show center divider", "default": true },
    { "type": "text", "id": "divider_text", "label": "Divider text", "default": "/" }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background image" },
        { "type": "text", "id": "kicker", "label": "Kicker" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "text", "label": "Body text" },
        { "type": "text", "id": "button_label", "label": "Button label" },
        { "type": "url", "id": "button_link", "label": "Button link" },
        { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#c8102e" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Motley Split Hero",
      "blocks": [
        { "type": "panel", "settings": { "kicker": "For the block", "heading": "STREET", "text": "Loud frames for loud lives.", "button_label": "Shop Street", "accent_color": "#c8102e" } },
        { "type": "panel", "settings": { "kicker": "For the send", "heading": "PERFORMANCE", "text": "Built to send it.", "button_label": "Shop Performance", "accent_color": "#1e4fd8" } }
      ]
    }
  ]
}
{% endschema %}

        "question_mRxzN7": {
          "type": "question",
          "settings": {
            "title": "How long will it take to get my order?",
            "answer": "<p>All items will be shipped the same day or next business day. Our shipping methods include: UPS, FedEx or USPS. Please allow a reasonable amount of processing and shipping times. This usually occurs within 7 days of purchase depending on your shipping region.</p>"
          }
        },
        "question_CY8rgy": {
          "type": "question",
          "settings": {
            "title": "What's the status of my order?",
            "answer": "<p>After you place your order, you will receive an email confirmation from our website. When you order has been shipped you will receive and email (or a text message) with your tracking number. You can use the tracking number to get the most up to date information. If you have any questions, please email us at: Support@MotleyUSA.Com</p>"
          }
        },
        "question_FpTib3": {
          "type": "question",
          "settings": {
            "title": "How do I set up an exchange or return?",
            "answer": "<p>To exchange or set up a return, please contact Customer Service at:<a href=\"mailto:support@MotleyUSA.com\" title=\"mailto:support@MotleyUSA.com\">Support@MotleyUSA.com</a>They will give you Return Authorization Number. </p>"
